# =============================================================
# URL Shortener — Environment Variables
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
#
# cp .env.example .env
# =============================================================

# ---------------------------------------------------------------
# DATABASE (Neon PostgreSQL — required)
# ---------------------------------------------------------------
# Get this from: https://console.neon.tech → your project → Connection string
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxxx-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ---------------------------------------------------------------
# App (optional)
# ---------------------------------------------------------------
# Public base URL used when generating short links.
# In production, set this to your actual domain.
# If not set, falls back to the incoming request host.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
